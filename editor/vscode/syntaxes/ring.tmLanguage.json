{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ring",
  "scopeName": "source.ring",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#raw-strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.ring"
    },
    "strings": {
      "name": "string.quoted.double.ring",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ring",
          "match": "\\\\[\\\\\"nrt0]"
        },
        {
          "name": "meta.embedded.expression.ring",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.ring" } },
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.ring" } },
          "patterns": [{ "include": "source.ring" }]
        }
      ]
    },
    "raw-strings": {
      "name": "string.quoted.other.raw.ring",
      "begin": "r#\"",
      "end": "\"#"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ring",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.ring",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "match": "\\b(fn|let|var|struct|enum|match|impl|effect|handle|with|if|else|or|catch|test|return|for|in|pub|where|trait|try|mut)\\b",
      "name": "keyword.control.ring"
    },
    "types": {
      "match": "\\b(Int|Float|Str|String|Bool|Unit|Never|Option|Cell|Self)\\b",
      "name": "support.type.ring"
    },
    "constants": {
      "match": "\\b(true|false|none)\\b",
      "name": "constant.language.ring"
    },
    "operators": {
      "match": "(->|=>|\\?|::|\\.\\.)",
      "name": "keyword.operator.ring"
    },
    "functions": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.ring" }
      }
    },
    "identifiers": {
      "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
      "name": "entity.name.type.ring"
    }
  }
}
